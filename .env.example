# ─── DATABAS ────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/booking_portal"

# ─── REDIS ──────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL="https://YOUR_UPSTASH_URL"
UPSTASH_REDIS_REST_TOKEN="YOUR_UPSTASH_TOKEN"

# ─── PROVIDER ───────────────────────────────────────────────
# mock = MockBookingProvider (dev/staging)
# mews = MewsBookingProvider (prod)
BOOKING_PROVIDER="mock"

# ─── MEWS (aktiveras när riktiga credentials finns) ──────────
MEWS_API_URL="https://api.mews.com"
MEWS_CLIENT_TOKEN=""
MEWS_ACCESS_TOKEN=""

# ─── SWEDBANK PAY ────────────────────────────────────────────
SWEDBANK_PAY_BASE_URL="https://api.externalintegration.payex.com"
SWEDBANK_PAY_TOKEN=""
SWEDBANK_PAY_MERCHANT_ID=""
SWEDBANK_PAY_WEBHOOK_SECRET=""
# true = använd mock-checkout istället för riktigt Swedbank Pay (dev/staging)
SWEDBANK_PAY_MOCK="true"
# Publik version för klienten (Next.js kräver NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_SWEDBANK_PAY_MOCK="true"

# ─── MAIL ────────────────────────────────────────────────────
RESEND_API_KEY=""
RESEND_FROM_EMAIL="bokningar@DOMANNAMN.se"

# ─── APP ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_ENV="development"

# ─── CRON ────────────────────────────────────────────────────
# Slumpmässig hemlig sträng för cron-autentisering
CRON_SECRET=""
